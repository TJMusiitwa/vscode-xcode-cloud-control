{
  "name": "vscode-xcode-cloud-control",
  "displayName": "Xcode Cloud Control",
  "description": "Manage, monitor and trigger Xcode Cloud builds and workflows via App Store Connect API",
  "version": "0.0.1",
  "publisher": "xcode-cloud-control",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/TJMusiitwa/vscode-xcode-cloud-control"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "xcode",
    "xcode cloud",
    "ios",
    "macos",
    "apple",
    "ci",
    "cd",
    "builds",
    "app store connect"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xcodecloud",
          "title": "Xcode Cloud",
          "icon": "resources/xcode-cloud.svg"
        }
      ]
    },
    "views": {
      "xcodecloud": [
        {
          "id": "xcodecloudWorkflows",
          "name": "Workflows",
          "icon": "$(list-unordered)"
        },
        {
          "id": "xcodecloudBuildRuns",
          "name": "Build Runs",
          "icon": "$(history)"
        },
        {
          "id": "xcodecloudBuildActions",
          "name": "Build Actions",
          "icon": "$(list-tree)"
        },
        {
          "id": "xcodecloudWorkflowDetails",
          "name": "Workflow Details",
          "icon": "$(info)"
        }
      ]
    },
    "commands": [
      {
        "command": "xcodecloud.configureCredentials",
        "title": "Xcode Cloud: Configure App Store Connect Credentials",
        "icon": "$(key)"
      },
      {
        "command": "xcodecloud.refreshWorkflows",
        "title": "Xcode Cloud: Refresh Workflows",
        "icon": "$(refresh)"
      },
      {
        "command": "xcodecloud.refreshBuildRuns",
        "title": "Xcode Cloud: Refresh Build Runs",
        "icon": "$(refresh)"
      },
      {
        "command": "xcodecloud.triggerBuild",
        "title": "Xcode Cloud: Trigger Build",
        "icon": "$(play)"
      },
      {
        "command": "xcodecloud.cancelBuild",
        "title": "Xcode Cloud: Cancel Build",
        "icon": "$(debug-stop)"
      },
      {
        "command": "xcodecloud.viewBuildLogs",
        "title": "Xcode Cloud: View Build Logs",
        "icon": "$(output)"
      },
      {
        "command": "xcodecloud.openInBrowser",
        "title": "Xcode Cloud: Open in App Store Connect",
        "icon": "$(link-external)"
      },
      {
        "command": "xcodecloud.refreshBuildActions",
        "title": "Xcode Cloud: Refresh Build Actions",
        "icon": "$(refresh)"
      },
      {
        "command": "xcodecloud.viewWorkflowDetails",
        "title": "Xcode Cloud: View Workflow Details",
        "icon": "$(info)"
      },
      {
        "command": "xcodecloud.refreshWorkflowDetails",
        "title": "Xcode Cloud: Refresh Workflow Details",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "xcodecloud.refreshWorkflows",
          "when": "view == xcodecloudWorkflows",
          "group": "navigation"
        },
        {
          "command": "xcodecloud.refreshBuildRuns",
          "when": "view == xcodecloudBuildRuns",
          "group": "navigation"
        },
        {
          "command": "xcodecloud.refreshBuildActions",
          "when": "view == xcodecloudBuildActions",
          "group": "navigation"
        },
        {
          "command": "xcodecloud.refreshWorkflowDetails",
          "when": "view == xcodecloudWorkflowDetails",
          "group": "navigation"
        },
        {
          "command": "xcodecloud.configureCredentials",
          "when": "view == xcodecloudWorkflows || view == xcodecloudBuildRuns || view == xcodecloudBuildActions || view == xcodecloudWorkflowDetails",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "xcodecloud.triggerBuild",
          "when": "view == xcodecloudWorkflows && viewItem == workflow",
          "group": "inline"
        },
        {
          "command": "xcodecloud.triggerBuild",
          "when": "view == xcodecloudWorkflows && viewItem == workflow",
          "group": "1_actions@1"
        },
        {
          "command": "xcodecloud.cancelBuild",
          "when": "view == xcodecloudBuildRuns && viewItem == buildRunActive",
          "group": "inline"
        },
        {
          "command": "xcodecloud.cancelBuild",
          "when": "view == xcodecloudBuildRuns && viewItem == buildRunActive",
          "group": "1_actions@1"
        },
        {
          "command": "xcodecloud.viewBuildLogs",
          "when": "view == xcodecloudBuildRuns && viewItem =~ /buildRun/",
          "group": "1_actions@2"
        },
        {
          "command": "xcodecloud.openInBrowser",
          "when": "view == xcodecloudWorkflows || view == xcodecloudBuildRuns",
          "group": "2_navigation@1"
        },
        {
          "command": "xcodecloud.viewWorkflowDetails",
          "when": "view == xcodecloudWorkflows && viewItem == workflow",
          "group": "1_actions@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "deploy": "vsce publish"
  },
  "dependencies": {
    "jose": "^5.9.3",
    "undici": "^6.21.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.1",
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  }
}
